# Supabase Configuration
# Copy this file to .env and replace with your actual credentials
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Application Configuration
ENVIRONMENT=development

# JWT Configuration (for local development, use the value from 'npx supabase status')
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Email (Resend) - required for password reset
# Get API key from https://resend.com/api-keys after verifying your domain
RESEND_API_KEY=re_your_api_key_here
APP_BASE_URL=http://localhost:8080
RESEND_FROM_ADDRESS=noreply@missingtable.com